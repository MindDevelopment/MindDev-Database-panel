      <div id="view-query" class="view">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
          <h2 style="margin-bottom:0">SQL Query</h2>
          <div style="display:flex;gap:6px">
            <button class="btn btn-sm" onclick="showQueryHistory()" style="background:rgba(59,130,246,0.1);color:var(--accent)"><i class="lucide-history"></i> History</button>
            <button class="btn btn-sm" onclick="showQueryBookmarks()" style="background:rgba(245,158,11,0.1);color:var(--warning)"><i class="lucide-bookmark"></i> Bookmarks</button>
          </div>
        </div>
        <div class="query-tabs" id="queryTabs">
          <div class="query-tab active" data-tab="0" onclick="switchQueryTab(0)">Query 1 <span class="query-tab-close" onclick="event.stopPropagation();closeQueryTab(0)">&times;</span></div>
          <button class="query-tab-add" onclick="addQueryTab()"><i class="lucide-plus"></i></button>
        </div>
        <div class="query-editor">
          <div class="query-toolbar">
            <button class="btn btn-sm" onclick="formatSQL()" title="Format SQL"><i class="lucide-align-left"></i> Format</button>
