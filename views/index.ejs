  <div id="toastContainer" class="toast-container"></div>
  <div class="app-layout" id="appLayout">
    <button class="menu-toggle" onclick="toggleSidebar()" id="menuToggle">&#9776;</button>
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <h2><%= (creds.type || 'postgres').charAt(0).toUpperCase() + (creds.type || 'postgres').slice(1) %></h2>
          <button class="theme-toggle" onclick="toggleTheme()" id="themeToggle" title="Toggle theme"><i class="lucide-moon"></i></button>
        </div>
        <div class="db-type-badge"><%= creds.type || 'postgres' %></div>
