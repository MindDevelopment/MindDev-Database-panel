<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Database Manager</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@latest/font/lucide.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<% if (view === 'setup') { %>
  <div class="login-container">
    <div class="login-card" style="max-width:560px">
      <h1>Database Manager</h1>
      <p class="subtitle">Step 1: Choose which databases to use</p>
      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>
      <form method="POST" action="/setup">
        <div class="setup-types">
          <label class="setup-type">
            <input type="checkbox" name="db_pg" value="1" onchange="toggleDbForm('pg', this.checked)" <%= current.pg ? 'checked' : '' %>>
            <span class="setup-type-label">PostgreSQL</span>
          </label>
          <div id="pg-form" class="setup-db-form" style="<%= current.pg ? '' : 'display:none' %>">
            <div class="form-row">
              <div class="form-group" style="flex:2"><label>Host</label><input type="text" name="pg_host" placeholder="localhost" value="localhost"></div>
              <div class="form-group" style="flex:1"><label>Port</label><input type="text" name="pg_port" placeholder="5432" value="5432"></div>
            </div>
            <div class="form-group"><label>User</label><input type="text" name="pg_user" placeholder="postgres" value="postgres"></div>
            <div class="form-group"><label>Password</label><input type="password" name="pg_password" placeholder=""></div>
            <div class="form-group"><label>Database (admin)</label><input type="text" name="pg_database" placeholder="postgres" value="postgres"></div>
          </div>

          <label class="setup-type">
            <input type="checkbox" name="db_mysql" value="1" onchange="toggleDbForm('mysql', this.checked)" <%= current.mysql ? 'checked' : '' %>>
            <span class="setup-type-label">MySQL</span>
          </label>
          <div id="mysql-form" class="setup-db-form" style="<%= current.mysql ? '' : 'display:none' %>">
            <div class="form-row">
              <div class="form-group" style="flex:2"><label>Host</label><input type="text" name="mysql_host" placeholder="localhost" value="localhost"></div>
              <div class="form-group" style="flex:1"><label>Port</label><input type="text" name="mysql_port" placeholder="3306" value="3306"></div>
            </div>
            <div class="form-group"><label>User</label><input type="text" name="mysql_user" placeholder="root" value="root"></div>
            <div class="form-group"><label>Password</label><input type="password" name="mysql_password" placeholder=""></div>
          </div>

          <label class="setup-type">
            <input type="checkbox" name="db_mariadb" value="1" onchange="toggleDbForm('mariadb', this.checked)" <%= current.mariadb ? 'checked' : '' %>>
            <span class="setup-type-label">MariaDB</span>
          </label>
          <div id="mariadb-form" class="setup-db-form" style="<%= current.mariadb ? '' : 'display:none' %>">
            <div class="form-row">
              <div class="form-group" style="flex:2"><label>Host</label><input type="text" name="mariadb_host" placeholder="localhost" value="localhost"></div>
              <div class="form-group" style="flex:1"><label>Port</label><input type="text" name="mariadb_port" placeholder="3306" value="3306"></div>
            </div>
            <div class="form-group"><label>User</label><input type="text" name="mariadb_user" placeholder="root" value="root"></div>
            <div class="form-group"><label>Password</label><input type="password" name="mariadb_password" placeholder=""></div>
          </div>
        </div>
        <button type="submit" class="btn btn-primary" style="margin-top:20px"><i class="lucide-check" style="margin-right:4px"></i> Save &amp; continue</button>
      </form>
    </div>
  </div>
  <script>
  function toggleDbForm(type, show) {
    document.getElementById(type + '-form').style.display = show ? '' : 'none';
  }
  </script>

<% } else if (view === 'login') { %>
  <div class="login-container">
    <div class="login-card">
      <h1>Database Manager</h1>
      <p class="subtitle">Log in to the database</p>
      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <% if (dbTypes && dbTypes.length > 1) { %>
        <div class="form-group">
          <label for="db_type">Database type</label>
          <select id="db_type" name="db_type">
            <% dbTypes.forEach(function(t) { %>
              <option value="<%= t %>"><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
            <% }); %>
          </select>
        </div>
        <% } else { %>
          <input type="hidden" name="db_type" value="<%= dbTypes ? dbTypes[0] : 'postgres' %>">
        <% } %>
        <div class="form-group">
          <label for="user">User</label>
          <input type="text" id="user" name="user" required autofocus>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required>
        </div>
        <div class="form-group">
          <label for="database">Database <small>(optional — leave empty to see all databases)</small></label>
          <input type="text" id="database" name="database" placeholder="">
        </div>
        <button type="submit" class="btn btn-primary">Log in</button>
      </form>
    </div>
  </div>

<% } else if (view === 'databases') { %>
  <div class="login-container">
    <div class="login-card" style="max-width:700px">
      <h1>Choose a database</h1>
      <p class="subtitle">Logged in as <strong><%= creds.user %></strong></p>
      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>
      <div class="db-list">
        <% databases.forEach(function(db) { %>
          <form method="POST" action="/select-database">
            <input type="hidden" name="database" value="<%= db.name %>">
            <button type="submit" class="db-choice"><%= db.name %></button>
          </form>
        <% }); %>
      </div>

      <div id="adminSection" style="display:none;margin-top:24px;border-top:1px solid #2a3a4a;padding-top:20px">
        <h3 style="color:#fff;margin-bottom:12px">&#9881; Management</h3>
        <div class="admin-tabs">
          <button class="admin-tab active" onclick="showAdmTab('users')">Users</button>
          <button class="admin-tab" onclick="showAdmTab('databases')">Databases</button>
          <button class="admin-tab" onclick="showAdmTab('permissions')">Permissions</button>
        </div>
        <div id="adm-users" class="admin-tab-content active">
          <div class="admin-section-header">
            <h4 style="color:#aabbcc">Users / Roles</h4>
            <button class="btn btn-primary" onclick="showAdmCreateUser()" style="width:auto;margin:0"><i class="lucide-user-plus" style="margin-right:4px"></i> New user</button>
          </div>
          <div id="admCreateUserForm" class="admin-form" style="display:none">
            <div class="form-group"><label>Username</label><input type="text" id="admNewUserName"></div>
            <div class="form-group" id="admHostGroup" style="display:none"><label>Host (e.g. localhost, %)</label><input type="text" id="admNewUserHost" placeholder="%"></div>
            <div class="form-group"><label>Password</label><input type="text" id="admNewUserPass"></div>
            <div class="form-row">
              <label class="chk"><input type="checkbox" id="admCanLogin" checked> Can login</label>
              <label class="chk"><input type="checkbox" id="admSuperuser"> Superuser</label>
              <label class="chk"><input type="checkbox" id="admCreateDb"> Can create databases</label>
              <label class="chk"><input type="checkbox" id="admCreateRole"> Can create roles</label>
            </div>
            <div class="form-actions">
              <button class="btn btn-primary" onclick="admCreateUser()" style="width:auto"><i class="lucide-check" style="margin-right:4px"></i> Create</button>
              <button class="btn" onclick="admHideCreateUser()" style="width:auto;background:rgba(51,65,85,0.5)">Cancel</button>
            </div>
          </div>
          <div id="admUsersList" class="admin-list"></div>
        </div>
        <div id="adm-databases" class="admin-tab-content">
          <div class="admin-section-header">
            <h4 style="color:#aabbcc">Databases</h4>
            <button class="btn btn-primary" onclick="showAdmCreateDb()" style="width:auto;margin:0"><i class="lucide-database" style="margin-right:4px"></i> New database</button>
          </div>
          <div id="admCreateDbForm" class="admin-form" style="display:none">
            <div class="form-group"><label>Database name</label><input type="text" id="admNewDbName"></div>
            <div class="form-group" id="admOwnerGroup"><label>Owner (empty = current user)</label><input type="text" id="admNewDbOwner"></div>
            <div class="form-actions">
              <button class="btn btn-primary" onclick="admCreateDb()" style="width:auto"><i class="lucide-check" style="margin-right:4px"></i> Create</button>
              <button class="btn" onclick="admHideCreateDb()" style="width:auto;background:rgba(51,65,85,0.5)">Cancel</button>
            </div>
          </div>
          <div id="admDbsList" class="admin-list"></div>
        </div>
        <div id="adm-permissions" class="admin-tab-content">
          <h4 style="color:#aabbcc;margin-bottom:12px">Manage permissions</h4>
          <div class="admin-form">
            <div class="form-group"><label>User</label><select id="admPermUser"></select></div>
            <div class="form-group"><label>Database</label><select id="admPermDb"></select></div>
            <div class="form-group">
              <label>Privilege</label>
              <select id="admPermPriv">
                <option value="SELECT">SELECT (Read)</option>
                <option value="INSERT">INSERT (Insert)</option>
                <option value="UPDATE">UPDATE (Update)</option>
                <option value="DELETE">DELETE (Delete)</option>
                <option value="ALL">ALL (All)</option>
              </select>
            </div>
            <div class="form-actions" style="flex-wrap:wrap">
              <button class="btn btn-primary" onclick="admGrantPerm()" style="width:auto"><i class="lucide-shield-check" style="margin-right:4px"></i> Grant</button>
              <button class="btn" onclick="admRevokePerm()" style="width:auto;background:var(--danger-bg);color:var(--danger);border:1px solid rgba(239,68,68,0.2)"><i class="lucide-shield-x" style="margin-right:4px"></i> Revoke</button>
              <button class="btn" onclick="admGrantDb()" style="width:auto;background:var(--success-bg);color:var(--success);border:1px solid rgba(34,197,94,0.2)"><i class="lucide-database" style="margin-right:4px"></i> Grant DB</button>
              <button class="btn" onclick="admRevokeDb()" style="width:auto;background:rgba(245,158,11,0.1);color:var(--warning);border:1px solid rgba(245,158,11,0.2)"><i class="lucide-database" style="margin-right:4px"></i> Revoke DB</button>
            </div>
          </div>
          <div id="admPermResult" class="admin-list" style="margin-top:12px"></div>
        </div>
      </div>

      <div style="margin-top: 16px; text-align: center;">
        <a href="/logout" class="logout-link">Log out</a>
      </div>
    </div>
  </div>

<script>
let admDbType = 'postgres';
(async function() {
  try {
    const r = await fetch('/admin/check'); const d = await r.json();
    admDbType = d.type || 'postgres';
    if (d.superuser) {
      document.getElementById('adminSection').style.display = '';
      showAdmTab('users');
    }
  } catch(e) {}
})();
function showAdmTab(t) {
  document.querySelectorAll('#adminSection .admin-tab-content').forEach(e=>e.classList.remove('active'));
  document.querySelectorAll('#adminSection .admin-tab').forEach(e=>e.classList.remove('active'));
  document.getElementById('adm-'+t).classList.add('active');
  document.querySelector('#adminSection .admin-tab[onclick*="'+t+'"]').classList.add('active');
  if (t==='users') admLoadUsers();
  if (t==='databases') admLoadDbs();
  if (t==='permissions') { admLoadPermUsers(); admLoadPermDbs(); }
}
async function admLoadUsers() {
  const el=document.getElementById('admUsersList'); el.innerHTML='<div class="loading">Loading...</div>';
  try {
    const r=await fetch('/admin/roles');
    if (!r.ok) { el.innerHTML=`<div class="alert error">Load error (${r.status})</div>`; return; }
    const roles=await r.json();
    if (!Array.isArray(roles)) { el.innerHTML=`<div class="alert error">Invalid response</div>`; return; }
    let html='<div class="table-wrapper"><table><thead><tr><th>User</th><th>Superuser</th><th>CreateDB</th><th>CreateRole</th><th></th></tr></thead><tbody>';
    roles.forEach(r => {
            html+=`<tr><td><strong>${r.rolname}</strong></td><td>${r.rolsuper?'<span style="color:var(--success)">&#10003;</span>':''}</td><td>${r.rolcreatedb?'<span style="color:var(--success)">&#10003;</span>':''}</td><td>${r.rolcreaterole?'<span style="color:var(--success)">&#10003;</span>':''}</td><td><button class="btn-sm" onclick="admDelRole('${r.rolname.replace(/'/g, "\\'")}')" style="background:var(--danger);padding:4px 10px"><i class="lucide-trash-2" style="font-size:12px"></i></button></td></tr>`;
    });
    html+='</tbody></table></div>';
    el.innerHTML=html;
  } catch(e) { el.innerHTML=`<div class="alert error">${e.message}</div>`; }
}
function showAdmCreateUser() {
  const f=document.getElementById('admCreateUserForm');
  document.getElementById('admHostGroup').style.display = (admDbType !== 'postgres') ? '' : 'none';
  f.style.display='block'; document.getElementById('admNewUserName').focus();
}
function admHideCreateUser() { document.getElementById('admCreateUserForm').style.display='none'; }
async function admCreateUser() {
  const n=document.getElementById('admNewUserName').value.trim(); if(!n) return alert('Enter a username');
  const body = {
    name:n, password:document.getElementById('admNewUserPass').value,
    canLogin:document.getElementById('admCanLogin').checked,
    superuser:document.getElementById('admSuperuser').checked,
    createDb:document.getElementById('admCreateDb').checked,
    createRole:document.getElementById('admCreateRole').checked
  };
  if (admDbType !== 'postgres') body.host = document.getElementById('admNewUserHost').value.trim() || '%';
  const r=await fetch('/admin/role',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  const d=await r.json();
  if(d.error) return alert('Error: '+d.error);
  admHideCreateUser();
  document.getElementById('admNewUserName').value=''; document.getElementById('admNewUserPass').value='';
  admLoadUsers();
}
async function admDelRole(name) {
  if(!confirm(`Delete "${name}"?`)) return;
  const r=await fetch(`/admin/role/${encodeURIComponent(name)}`,{method:'DELETE'}); const d=await r.json();
  if(d.error) return alert('Error: '+d.error); admLoadUsers();
}
async function admLoadDbs() {
  const el=document.getElementById('admDbsList'); el.innerHTML='<div class="loading">Loading...</div>';
  try {
    const r=await fetch('/admin/dbs');
    if (!r.ok) { el.innerHTML=`<div class="alert error">Load error (${r.status})</div>`; return; }
    const dbs=await r.json();
    if (!Array.isArray(dbs)) { el.innerHTML=`<div class="alert error">Invalid response</div>`; return; }
    let html='<div class="table-wrapper"><table><thead><tr><th>Database</th><th>Size</th><th>Owner</th><th></th></tr></thead><tbody>';
    dbs.forEach(d => {
      html+=`<tr><td><strong>${d.datname}</strong></td><td>${d.size||'?'}</td><td>${d.owner||'-'}</td><td><button class="btn-sm" onclick="admDelDb('${d.datname.replace(/'/g, "\\'")}')" style="background:var(--danger);padding:4px 10px"><i class="lucide-trash-2" style="font-size:12px"></i></button></td></tr>`;
    });
    html+='</tbody></table></div>';
    el.innerHTML=html;
  } catch(e) { el.innerHTML=`<div class="alert error">${e.message}</div>`; }
}
function showAdmCreateDb() {
  document.getElementById('admOwnerGroup').style.display = (admDbType === 'postgres') ? '' : 'none';
  document.getElementById('admCreateDbForm').style.display='block';
}
function admHideCreateDb() { document.getElementById('admCreateDbForm').style.display='none'; }
async function admCreateDb() {
  const n=document.getElementById('admNewDbName').value.trim(); if(!n) return alert('Enter a database name');
  const body = {name:n};
  if (admDbType === 'postgres') body.owner = document.getElementById('admNewDbOwner').value.trim()||undefined;
  const r=await fetch('/admin/db',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  const d=await r.json(); if(d.error) return alert('Error: '+d.error);
  admHideCreateDb(); document.getElementById('admNewDbName').value=''; if(admDbType==='postgres') document.getElementById('admNewDbOwner').value=''; admLoadDbs();
}
async function admDelDb(name) {
  if(!confirm(`Delete database "${name}"?\n\nThis cannot be undone!`)) return;
  const r=await fetch(`/admin/db/${encodeURIComponent(name)}`,{method:'DELETE'}); const d=await r.json();
  if(d.error) return alert('Error: '+d.error); admLoadDbs();
}
async function admLoadPermUsers() {
  const sel=document.getElementById('admPermUser');
  try {
    const r=await fetch('/admin/roles');
    if (!r.ok) { sel.innerHTML='<option>Load error</option>'; return; }
    const roles=await r.json();
    if (!Array.isArray(roles)) { sel.innerHTML='<option>Invalid response</option>'; return; }
    sel.innerHTML=roles.filter(r=>r.rolcanlogin).map(r=>`<option value="${r.rolname}">${r.rolname}</option>`).join('');
  } catch(e) { sel.innerHTML='<option>Error</option>'; }
}
async function admLoadPermDbs() {
  const sel=document.getElementById('admPermDb');
  const label = (admDbType === 'postgres') ? 'All databases (public schema)' : 'All databases (*)';
  sel.innerHTML='<option value="*ALL*">'+label+'</option>';
  try {
    const r=await fetch('/admin/dbs');
    if (!r.ok) return;
    const dbs=await r.json();
    if (!Array.isArray(dbs)) return;
    dbs.forEach(d=>{sel.innerHTML+=`<option value="${d.datname}">${d.datname}</option>`;});
  } catch(e) {}
}
async function admGrantPerm() {
  const role=document.getElementById('admPermUser').value,db=document.getElementById('admPermDb').value,priv=document.getElementById('admPermPriv').value;
  if(!role) return alert('Select a user');
  const r=await fetch('/admin/grant',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({role,database:db,privilege:priv})});
  const d=await r.json();
  document.getElementById('admPermResult').innerHTML=d.success?'<div class="alert" style="background:var(--success-bg);color:#86efac;border:1px solid rgba(34,197,94,0.2)"><i class="lucide-check-circle" style="margin-right:6px"></i> Permissions granted!</div>':`<div class="alert error">${d.error}</div>`;
}
async function admGrantDb() {
  const role=document.getElementById('admPermUser').value,db=document.getElementById('admPermDb').value;
  if(!role||db==='*ALL*') return alert('Select a user and a specific database');
  const r=await fetch('/admin/grant-db',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({role,database:db})});
  const d=await r.json();
  document.getElementById('admPermResult').innerHTML=d.success?'<div class="alert" style="background:var(--success-bg);color:#86efac;border:1px solid rgba(34,197,94,0.2)"><i class="lucide-check-circle" style="margin-right:6px"></i> Access granted!</div>':`<div class="alert error">${d.error}</div>`;
}
async function admRevokePerm() {
  const role=document.getElementById('admPermUser').value,db=document.getElementById('admPermDb').value,priv=document.getElementById('admPermPriv').value;
  if(!role) return alert('Select a user');
  const r=await fetch('/admin/revoke',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({role,database:db,privilege:priv})});
  const d=await r.json();
  document.getElementById('admPermResult').innerHTML=d.success?'<div class="alert" style="background:var(--danger-bg);color:#fca5a5;border:1px solid rgba(239,68,68,0.2)"><i class="lucide-x-circle" style="margin-right:6px"></i> Permissions revoked!</div>':`<div class="alert error">${d.error}</div>`;
}
async function admRevokeDb() {
  const role=document.getElementById('admPermUser').value,db=document.getElementById('admPermDb').value;
  if(!role||db==='*ALL*') return alert('Select a user and a specific database');
  const r=await fetch('/admin/revoke-db',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({role,database:db})});
  const d=await r.json();
  document.getElementById('admPermResult').innerHTML=d.success?'<div class="alert" style="background:var(--danger-bg);color:#fca5a5;border:1px solid rgba(239,68,68,0.2)"><i class="lucide-x-circle" style="margin-right:6px"></i> Access revoked!</div>':`<div class="alert error">${d.error}</div>`;
}
</script>

<% } else if (view === 'admin') { %>
  <div class="login-container">
    <div class="login-card" style="max-width:700px">
      <h1>Admin Panel</h1>
      <p class="subtitle">Logged in as <strong><%= creds.user %></strong></p>
      <div class="admin-tabs">
        <button class="admin-tab active" onclick="showAdminTab2('users')">Users</button>
        <button class="admin-tab" onclick="showAdminTab2('databases')">Databases</button>
        <button class="admin-tab" onclick="showAdminTab2('permissions')">Permissions</button>
      </div>

      <div id="admin2-users" class="admin-tab-content active">
        <div class="admin-section-header">
          <h3 style="color:#fff">Users / Roles</h3>
          <button class="btn btn-primary" onclick="showCreateUser2()" style="width:auto;margin:0"><i class="lucide-user-plus" style="margin-right:4px"></i> New user</button>
        </div>
        <div id="createUserForm2" class="admin-form" style="display:none">
          <h4>New user</h4>
          <div class="form-group"><label>Username</label><input type="text" id="newUserName2"></div>
          <div class="form-group"><label>Password</label><input type="text" id="newUserPassword2"></div>
          <div class="form-row">
            <label class="chk"><input type="checkbox" id="newUserCanLogin2" checked> Can login</label>
            <label class="chk"><input type="checkbox" id="newUserSuperuser2"> Superuser</label>
            <label class="chk"><input type="checkbox" id="newUserCreateDb2"> Can create databases</label>
            <label class="chk"><input type="checkbox" id="newUserCreateRole2"> Can create roles</label>
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" onclick="createUser2()" style="width:auto"><i class="lucide-check" style="margin-right:4px"></i> Create</button>
            <button class="btn" onclick="hideCreateUser2()" style="width:auto;background:rgba(51,65,85,0.5)">Cancel</button>
          </div>
        </div>
        <div id="usersList2" class="admin-list"></div>
      </div>

      <div id="admin2-databases" class="admin-tab-content">
        <div class="admin-section-header">
          <h3 style="color:#fff">Databases</h3>
          <button class="btn btn-primary" onclick="showCreateDb2()" style="width:auto;margin:0"><i class="lucide-database" style="margin-right:4px"></i> New database</button>
        </div>
        <div id="createDbForm2" class="admin-form" style="display:none">
          <h4>New database</h4>
          <div class="form-group"><label>Database name</label><input type="text" id="newDbName2"></div>
          <div class="form-group"><label>Owner (empty = current user)</label><input type="text" id="newDbOwner2"></div>
          <div class="form-actions">
            <button class="btn btn-primary" onclick="createDb2()" style="width:auto"><i class="lucide-check" style="margin-right:4px"></i> Create</button>
            <button class="btn" onclick="hideCreateDb2()" style="width:auto;background:rgba(51,65,85,0.5)">Cancel</button>
          </div>
        </div>
        <div id="databasesList2" class="admin-list"></div>
      </div>

      <div id="admin2-permissions" class="admin-tab-content">
        <h3 style="color:#fff;margin-bottom:12px">Manage permissions</h3>
        <div class="admin-form">
          <div class="form-group"><label>User</label><select id="permUser2"></select></div>
          <div class="form-group"><label>Database</label><select id="permDb2"></select></div>
          <div class="form-group">
            <label>Privilege</label>
            <select id="permPrivilege2">
              <option value="SELECT">SELECT (Read)</option>
              <option value="INSERT">INSERT (Insert)</option>
              <option value="UPDATE">UPDATE (Update)</option>
              <option value="DELETE">DELETE (Delete)</option>
              <option value="ALL">ALL (All)</option>
            </select>
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" onclick="grantPermission2()" style="width:auto"><i class="lucide-shield-check" style="margin-right:4px"></i> Grant</button>
            <button class="btn" onclick="grantDbAccess2()" style="width:auto;background:var(--success-bg);color:var(--success);border:1px solid rgba(34,197,94,0.2)"><i class="lucide-database" style="margin-right:4px"></i> Grant DB access</button>
          </div>
        </div>
        <div id="permResult2" class="admin-list" style="margin-top:12px"></div>
      </div>

      <div style="margin-top:20px;text-align:center">
        <a href="/databases" class="admin-link" style="display:inline-flex;align-items:center;gap:6px;padding:10px 20px;background:linear-gradient(135deg,var(--accent),#2563eb);color:#fff;border-radius:8px;text-decoration:none;font-size:13px;font-weight:600;box-shadow:0 4px 12px rgba(59,130,246,0.3)"><i class="lucide-repeat-2"></i> Go to databases</a>
        <br><br>
        <a href="/logout" class="logout-link">Log out</a>
      </div>
    </div>
  </div>

<script>
function showAdminTab2(tab) {
  document.querySelectorAll('#admin2-' + tab).forEach(el => {
    document.querySelectorAll('.admin-tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('admin2-' + tab).classList.add('active');
    document.querySelector('.admin-tab[onclick*="' + tab + '"]').classList.add('active');
    if (tab === 'users') loadUsers2();
    if (tab === 'databases') loadAdminDbs2();
    if (tab === 'permissions') { loadPermUsers2(); loadPermDbs2(); }
  });
}
async function loadUsers2() {
  const el = document.getElementById('usersList2');
  el.innerHTML = '<div class="loading">Loading...</div>';
  try {
    const res = await fetch('/admin/roles');
    const roles = await res.json();
    if (roles.error) throw new Error(roles.error);
    el.innerHTML = '<div class="table-wrapper"><table><thead><tr><th>Role</th><th>Superuser</th><th>Login</th><th>Create DB</th><th>Create Role</th><th>Connections</th><th></th></tr></thead><tbody>' +
      roles.map(r => `<tr><td><strong>${r.rolname}</strong></td><td>${r.rolsuper?'<span style="color:var(--success)">&#10003;</span>':''}</td><td>${r.rolcanlogin?'<span style="color:var(--success)">&#10003;</span>':''}</td><td>${r.rolcreatedb?'<span style="color:var(--success)">&#10003;</span>':''}</td><td>${r.rolcreaterole?'<span style="color:var(--success)">&#10003;</span>':''}</td><td>${r.rolconnlimit}</td><td><button class="btn-sm" onclick="deleteRole2('${r.rolname}')" style="background:var(--danger);padding:4px 10px"><i class="lucide-trash-2" style="font-size:12px"></i></button></td></tr>`).join('') + '</tbody></table></div>';
  } catch (err) { el.innerHTML = `<div class="alert error">${err.message}</div>`; }
}
function showCreateUser2() { document.getElementById('createUserForm2').style.display='block'; }
function hideCreateUser2() { document.getElementById('createUserForm2').style.display='none'; }
async function createUser2() {
  const name = document.getElementById('newUserName2').value.trim();
  if (!name) return alert('Enter a username');
  const r = await fetch('/admin/role', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
    name, password: document.getElementById('newUserPassword2').value,
    canLogin: document.getElementById('newUserCanLogin2').checked,
    superuser: document.getElementById('newUserSuperuser2').checked,
    createDb: document.getElementById('newUserCreateDb2').checked,
    createRole: document.getElementById('newUserCreateRole2').checked
  })});
  const d = await r.json();
  if (d.error) return alert('Error: '+d.error);
  hideCreateUser2(); document.getElementById('newUserName2').value=''; document.getElementById('newUserPassword2').value='';
  loadUsers2();
}
async function deleteRole2(name) {
  if (!confirm(`Are you sure you want to delete "${name}"?`)) return;
  const r = await fetch(`/admin/role/${encodeURIComponent(name)}`,{method:'DELETE'});
  const d = await r.json();
  if (d.error) return alert('Error: '+d.error); loadUsers2();
}
async function loadAdminDbs2() {
  const el = document.getElementById('databasesList2');
  el.innerHTML = '<div class="loading">Loading...</div>';
  try {
    const res = await fetch('/admin/dbs');
    const dbs = await res.json();
    if (dbs.error) throw new Error(dbs.error);
    el.innerHTML = '<div class="table-wrapper"><table><thead><tr><th>Database</th><th>Size</th><th>Owner</th><th>Encoding</th><th></th></tr></thead><tbody>' +
      dbs.map(d => `<tr><td><strong>${d.datname}</strong></td><td>${d.size}</td><td>${d.owner}</td><td>${d.encoding}</td><td><button class="btn-sm" onclick="deleteDb2('${d.datname}')" style="background:var(--danger);padding:4px 10px"><i class="lucide-trash-2" style="font-size:12px"></i></button></td></tr>`).join('') + '</tbody></table></div>';
  } catch (err) { el.innerHTML = `<div class="alert error">${err.message}</div>`; }
}
function showCreateDb2() { document.getElementById('createDbForm2').style.display='block'; }
function hideCreateDb2() { document.getElementById('createDbForm2').style.display='none'; }
async function createDb2() {
  const name = document.getElementById('newDbName2').value.trim();
  if (!name) return alert('Enter a database name');
  const r = await fetch('/admin/db', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,owner:document.getElementById('newDbOwner2').value.trim()||undefined})});
  const d = await r.json();
  if (d.error) return alert('Error: '+d.error);
  hideCreateDb2(); document.getElementById('newDbName2').value=''; document.getElementById('newDbOwner2').value=''; loadAdminDbs2();
}
async function deleteDb2(name) {
  if (!confirm(`Are you sure you want to delete database "${name}"?\n\nThis cannot be undone!`)) return;
  const r = await fetch(`/admin/db/${encodeURIComponent(name)}`,{method:'DELETE'});
  const d = await r.json();
  if (d.error) return alert('Error: '+d.error); loadAdminDbs2();
}
async function loadPermUsers2() {
  const sel = document.getElementById('permUser2');
  const r = await fetch('/admin/roles'); const roles = await r.json();
  sel.innerHTML = roles.filter(r=>r.rolcanlogin).map(r=>`<option value="${r.rolname}">${r.rolname}</option>`).join('');
}
async function loadPermDbs2() {
  const sel = document.getElementById('permDb2');
  sel.innerHTML = '<option value="*ALL*">All databases (public schema)</option>';
  const r = await fetch('/admin/dbs'); const dbs = await r.json();
  dbs.forEach(d => { sel.innerHTML += `<option value="${d.datname}">${d.datname}</option>`; });
}
async function grantPermission2() {
  const role = document.getElementById('permUser2').value;
  const database = document.getElementById('permDb2').value;
  const privilege = document.getElementById('permPrivilege2').value;
  if (!role) return alert('Select a user');
  const r = await fetch('/admin/grant', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({role,database,privilege})});
  const d = await r.json();
  document.getElementById('permResult2').innerHTML = d.success
    ? '<div class="alert" style="background:var(--success-bg);color:#86efac;border:1px solid rgba(34,197,94,0.2)"><i class="lucide-check-circle" style="margin-right:6px"></i> Permissions granted!</div>'
    : `<div class="alert error">${d.error}</div>`;
}
async function grantDbAccess2() {
  const role = document.getElementById('permUser2').value;
  const database = document.getElementById('permDb2').value;
  if (!role || database === '*ALL*') return alert('Select a user and a specific database');
  const r = await fetch('/admin/grant-db', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({role,database})});
  const d = await r.json();
  document.getElementById('permResult2').innerHTML = d.success
    ? '<div class="alert" style="background:var(--success-bg);color:#86efac;border:1px solid rgba(34,197,94,0.2)"><i class="lucide-check-circle" style="margin-right:6px"></i> Database access granted!</div>'
    : `<div class="alert error">${d.error}</div>`;
}
window.addEventListener('DOMContentLoaded', () => { showAdminTab2('users'); });
</script>

<% } else if (view === 'manager') { %>
  <div class="app-layout">
    <button class="menu-toggle" onclick="toggleSidebar()" id="menuToggle">&#9776;</button>
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h2><%= (creds.type || 'postgres').charAt(0).toUpperCase() + (creds.type || 'postgres').slice(1) %></h2>
        <div class="db-type-badge"><%= creds.type || 'postgres' %></div>
        <div class="db-info">
          <span class="db-name"><%= creds.database %></span>
          <span class="db-user"><%= creds.user %></span>
        </div>
      </div>
      <nav class="sidebar-nav">
        <button class="nav-btn active" data-view="overview" onclick="showView('overview')">
          <span class="icon"><i class="lucide-layout-dashboard"></i></span> Overview
        </button>
        <button class="nav-btn" data-view="tables" onclick="showView('tables')">
          <span class="icon"><i class="lucide-table-2"></i></span> Tables
        </button>
        <button class="nav-btn" data-view="query" onclick="showView('query')">
          <span class="icon"><i class="lucide-terminal"></i></span> SQL Query
        </button>
      </nav>
      <div class="table-list" id="tableList">
        <h3>Tables</h3>
        <div id="tableItems"></div>
      </div>
      <div class="sidebar-footer">
        <a href="/databases" class="nav-btn" style="justify-content: center; margin-bottom: 4px;"><i class="lucide-repeat-2" style="margin-right:6px"></i> Switch database</a>
        <a href="/logout" class="logout-btn">Log out</a>
      </div>
    </aside>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <main class="main-content">
      <div id="view-overview" class="view active">
        <h2>Database Overview</h2>
        <div id="overviewContent" class="overview-grid"></div>
      </div>

      <div id="view-tables" class="view">
        <h2>Database Explorer</h2>
        <div id="tableContent">
          <p class="hint">Select a table from the list on the left.</p>
        </div>
      </div>

      <div id="view-query" class="view">
        <h2>SQL Query</h2>
        <div class="query-editor">
          <textarea id="sqlInput" rows="6" placeholder="Enter SQL query..."></textarea>
          <button class="btn btn-primary" onclick="executeQuery()"><i class="lucide-play" style="margin-right:4px"></i> Execute</button>
        </div>
        <div id="queryResult"></div>
      </div>

    </main>
  </div>
<% } %>

<script>
<% if (view === 'manager') { %>
let currentTable = null;

function showView(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  document.querySelector(`.nav-btn[data-view="${view}"]`).classList.add('active');
  if (view === 'overview') loadOverview();
  if (view === 'tables') loadTables();
  if (window.innerWidth <= 768) toggleSidebar();
}

async function loadOverview() {
  try {
    const res = await fetch('/dashboard');
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    document.getElementById('overviewContent').innerHTML = `
      <div class="stat-card"><span class="stat-label">Database</span><span class="stat-value">${data.database}</span></div>
      <div class="stat-card"><span class="stat-label">User</span><span class="stat-value">${data.user}</span></div>
      <div class="stat-card"><span class="stat-label">Host</span><span class="stat-value">localhost</span></div>
      <div class="stat-card"><span class="stat-label">Size</span><span class="stat-value">${data.dbSize}</span></div>
      <div class="stat-card"><span class="stat-label">Tables</span><span class="stat-value">${data.tableCount}</span></div>
      <div class="stat-card"><span class="stat-label">Active connections</span><span class="stat-value">${data.activeConnections}</span></div>
    `;
  } catch (err) {
    document.getElementById('overviewContent').innerHTML = `<div class="alert error">${err.message}</div>`;
  }
}

async function loadTables() {
  try {
    const res = await fetch('/tables');
    const tables = await res.json();
    if (tables.error) throw new Error(tables.error);
    const list = document.getElementById('tableItems');
    list.innerHTML = tables.map(t =>
      `<a href="#" class="table-item" onclick="return selectTable('${t.table_schema}','${t.table_name}')">
        <span class="table-icon"><i class="lucide-table-2"></i></span> ${t.table_name}
        <small>${t.table_schema}</small>
      </a>`
    ).join('');
  } catch (err) {
    document.getElementById('tableItems').innerHTML = `<div class="alert error">${err.message}</div>`;
  }
}

async function selectTable(schema, name) {
  showView('tables');
  const container = document.getElementById('tableContent');
  container.innerHTML = '<div class="loading">Loading...</div>';
  try {
    const res = await fetch(`/table/${encodeURIComponent(schema)}/${encodeURIComponent(name)}`);
    const data = await res.json();
    if (data.error) throw new Error(data.error);

    const pkCol = data.columns[0]?.column_name || 'id';
    let html = `<h3>Table: ${schema}.${name}</h3>`;
    html += `<div style="margin-bottom:10px"><button class="btn btn-sm" onclick="exportCSV('${schema}','${name}')" style="background:#2a6a3a"><i class="lucide-download" style="margin-right:4px"></i> Export CSV</button></div>`;
    html += '<div class="table-wrapper"><table><thead><tr>';
    data.columns.forEach(c => { html += `<th>${c.column_name}<br><small>${c.data_type}</small></th>`; });
    html += '<th>Actions</th></tr></thead><tbody>';

    data.rows.forEach(row => {
      html += '<tr>';
      data.columns.forEach(c => {
        const val = row[c.column_name];
        html += `<td class="cell-editable" contenteditable="true"
          data-schema="${schema}" data-table="${name}"
          data-pkcol="${pkCol}" data-pkval="${row[pkCol]}"
          data-col="${c.column_name}">${val !== null && val !== undefined ? val : '<span class="null">NULL</span>'}</td>`;
      });
      html += '<td><button class="btn-sm" onclick="saveRow(this)"><i class="lucide-check" style="margin-right:3px"></i> Save</button></td>';
      html += '</tr>';
    });
    html += '</tbody></table></div>';
    container.innerHTML = html;
    currentTable = { schema, name, pkCol };
  } catch (err) {
    container.innerHTML = `<div class="alert error">${err.message}</div>`;
  }
}

async function saveRow(btn) {
  const row = btn.closest('tr');
  const cells = row.querySelectorAll('.cell-editable');
  const firstCell = cells[0];
  const schema = firstCell.dataset.schema;
  const table = firstCell.dataset.table;
  const pkCol = firstCell.dataset.pkcol;
  const pkVal = firstCell.dataset.pkval;
  const updates = {};
  cells.forEach(cell => {
    const val = cell.innerText.trim();
    if (val !== '' && val !== 'NULL') updates[cell.dataset.col] = val;
  });
  try {
    const res = await fetch(`/table/${encodeURIComponent(schema)}/${encodeURIComponent(table)}/${encodeURIComponent(pkCol)}/${encodeURIComponent(pkVal)}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(updates)
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    btn.textContent = 'Saved!';
    setTimeout(() => { btn.textContent = 'Save'; }, 2000);
  } catch (err) {
    alert('Error: ' + err.message);
  }
}

async function executeQuery() {
  const sql = document.getElementById('sqlInput').value;
  if (!sql.trim()) return;
  const container = document.getElementById('queryResult');
  container.innerHTML = '<div class="loading">Executing...</div>';
  try {
    const res = await fetch('/query', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sql })
    });
    const data = await res.json();
    if (data.error) throw new Error(data.error);
    let html = `<div class="query-meta">${data.command} — ${data.rowCount} row(s) — ${data.duration}ms</div>`;
    if (data.rows && data.rows.length > 0) {
      html += '<div class="table-wrapper"><table><thead><tr>';
      Object.keys(data.rows[0]).forEach(k => { html += `<th>${k}</th>`; });
      html += '</tr></thead><tbody>';
      data.rows.forEach(row => {
        html += '<tr>';
        Object.values(row).forEach(v => {
          html += `<td>${v !== null && v !== undefined ? v : '<span class="null">NULL</span>'}</td>`;
        });
        html += '</tr>';
      });
      html += '</tbody></table></div>';
    }
    container.innerHTML = html;
  } catch (err) {
    container.innerHTML = `<div class="alert error">${err.message}</div>`;
  }
}

function exportCSV(schema, name) {
  window.open(`/table/${encodeURIComponent(schema)}/${encodeURIComponent(name)}/export`, '_blank');
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('show');
}

window.addEventListener('DOMContentLoaded', () => {
  loadOverview();
  loadTables();
});
<% } %>
</script>
</body>
</html>