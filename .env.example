PORT=3100
HOST=0.0.0.0

# Enable databases: comma-separated (postgres, mysql, mariadb)
DB_TYPE=postgres

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=postgres

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=

# MariaDB
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=

SESSION_SECRET=change-this-to-a-random-secret
SESSION_MAX_AGE=86400000

POOL_HOST=localhost
POOL_PORT=5432
POOL_MAX=3
POOL_IDLE_TIMEOUT=10000
AUTH_POOL_MAX=2
AUTH_POOL_IDLE_TIMEOUT=5000
